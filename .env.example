APP_NAME="Casa Paraiso"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:18001
SUPER_ADMIN_EMAIL=admin@example.com
PROFILE_DELETION_REAUTH_TTL=600
PROFILE_PASSWORD_SETUP_REAUTH_TTL=600
APP_PORT=18001
VITE_PORT=5173
FORWARD_VITE_PORT=15173

APP_TIMEZONE=Asia/Manila

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
WWWUSER=1000
WWWGROUP=1000

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=casa_paraiso
DB_USERNAME=sail
DB_PASSWORD=password
FORWARD_DB_PORT=13307
POSTGRES_DB=casa_paraiso
POSTGRES_USER=sail
POSTGRES_PASSWORD=password
FORWARD_PGSQL_PORT=15432

# Account-preserving MariaDB to PostgreSQL transfer connections.
# Keep production credentials in the uncommitted .env only.
MIGRATION_SOURCE_DB_HOST=mariadb
MIGRATION_SOURCE_DB_PORT=3306
MIGRATION_SOURCE_DB_DATABASE=casa_paraiso
MIGRATION_SOURCE_DB_USERNAME=sail
MIGRATION_SOURCE_DB_PASSWORD=password
MIGRATION_TARGET_DB_HOST=pgsql
MIGRATION_TARGET_DB_PORT=5432
MIGRATION_TARGET_DB_DATABASE=casa_paraiso
MIGRATION_TARGET_DB_USERNAME=sail
MIGRATION_TARGET_DB_PASSWORD=password
MIGRATION_TARGET_DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# Production hardening: enable only after APP_URL uses HTTPS and the listed
# hosts match the deployed domain. Separate multiple hosts with commas.
FORCE_HTTPS=false
HSTS_ENABLED=false
TRUSTED_HOSTS=
MOBILE_DEMO_PAIRING_ENABLED=false
MOBILE_DEMO_INSTANCE_ID=
MOBILE_PAIRING_CACHE_STORE=file
MOBILE_GOOGLE_CACHE_STORE=file
MOBILE_CORS_ALLOWED_ORIGINS=https://localhost,capacitor://localhost,http://localhost:5173,http://127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Safe local default: Mailpit captures messages at http://localhost:18025.
# See docs/DOCKER_WORKFLOW.md before switching to Gmail SMTP or a public tunnel.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
FORWARD_MAILPIT_PORT=11026
FORWARD_MAILPIT_DASHBOARD_PORT=18025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
